# ─── OpenWeatherMap ───────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
WEATHER_LAT=40.7128
WEATHER_LON=-74.0060

# ─── Sobriety Counter ─────────────────────────────────────────────────────────
# ISO 8601 date-time string — the moment sobriety began
SOBRIETY_DATE=2025-07-07T00:00:00
# Frontend build-time copy (Vite requires VITE_ prefix for client-side access)
VITE_SOBRIETY_DATE=2025-07-07T00:00:00

# ─── Plex ─────────────────────────────────────────────────────────────────────
PLEX_URL=http://192.168.1.100:32400
PLEX_TOKEN=your_plex_token_here

# ─── Calendar (ICS/CalDAV) ────────────────────────────────────────────────────
# Comma-separated list of ICS/CalDAV URLs (iCloud shared calendar links)
ICAL_URLS=https://p23-caldav.icloud.com/published/2/abc123,https://p23-caldav.icloud.com/published/2/xyz456

# ─── iCloud Shared Photos Album ───────────────────────────────────────────────
ICLOUD_ALBUM_URL=https://www.icloud.com/photos/share/your_token_here

# ─── Pi-hole ─────────────────────────────────────────────────────────────────
PIHOLE_URL=http://192.168.1.100
PIHOLE_PASSWORD=your_pihole_password_here

# ─── Server Ports ─────────────────────────────────────────────────────────────
PORT=3000
BACKEND_PORT=3001
